<Window x:Class="ModernZamanTakip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus to Atlas" Height="750" Width="1200"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterScreen" Icon="dunya.png">

    <Window.Resources>
        <Storyboard x:Key="RotationStoryboard">
            <DoubleAnimation Storyboard.TargetName="worldRotateTransform"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:2:0" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource RotationStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Margin="30" CornerRadius="40">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="80" ShadowDepth="25" Opacity="0.8"/>
        </Border.Effect>
        <Grid>
            <Border CornerRadius="40">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.2" EndPoint="1,1">
                        <GradientStop Color="#1C1C21" Offset="0"/>
                        <GradientStop Color="#0A0A0C" Offset="0.5"/>
                        <GradientStop Color="#000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Viewbox x:Name="worldContainer" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-200,-300" Width="900" Height="900" Opacity="0.85">
                <Grid>
                    <Image Source="dunya.png" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5" Margin="0,-108,0,108">
                        <Image.RenderTransform>
                            <RotateTransform x:Name="worldRotateTransform" Angle="0"/>
                        </Image.RenderTransform>
                    </Image>
                </Grid>
            </Viewbox>

            <Border x:Name="StatsArkaPlanKarartma" Background="#E60A0A0C" CornerRadius="40" Visibility="Collapsed"/>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="40,10,40,0">
                    <TextBlock Text="▮ F O C U S  t o  A T L A S" Foreground="#A0A0A5" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="✕" Foreground="#A0A0A5" FontSize="18" Cursor="Hand" MouseLeftButtonDown="btnKapat_Click" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="AnaEkranView" Grid.Row="1" Visibility="Visible">

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="100,-80,0,0">
                        <TextBlock x:Name="lblTarih" Text="1 Ocak 2026, Pazartesi" Foreground="#00E676" FontSize="20" FontWeight="SemiBold" Margin="10,0,0,0" Opacity="0.8"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="lblSayac" Text="00:00" Foreground="White" FontSize="180" FontWeight="UltraLight" HorizontalAlignment="Left" Margin="0,-10,0,20"/>
                            <Button x:Name="btnMiniEkranaGec" Content="▶" FontSize="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Foreground="White" Margin="20,0,0,0" Click="btnMiniEkranaGec_Click" VerticalAlignment="Top"/>
                        </StackPanel>

                        <Button x:Name="btnBaslat" Content="B  A  Ş  L  A  T" Width="260" Height="50" FontSize="16" FontWeight="SemiBold" Foreground="White" Cursor="Hand" Click="btnBaslat_Click" HorizontalAlignment="Left">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Grid>
                                        <Border Background="#00E676" CornerRadius="25">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#00E676" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                                            </Border.Effect>
                                        </Border>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <Border Background="#1AFFFFFF" CornerRadius="20" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="80" Padding="15,0,15,0" Margin="100,0,0,50">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border MouseLeftButtonDown="btnIstatistikSayfasi_Click" Background="#2AFFFFFF" CornerRadius="10" Padding="20,10,20,10" Margin="10,0,10,0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="İstatistikler" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border MouseLeftButtonDown="btnManuelEkleAc_Click" Background="#2AFFFFFF" CornerRadius="10" Padding="20,10,20,10" Margin="10,0,10,0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✍️" FontSize="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Ekstra Ekle" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="IstatistiklerView" Grid.Row="1" Visibility="Collapsed" Margin="80,20,80,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Cursor="Hand" MouseLeftButtonDown="btnAnaEkranaDon_Click" Margin="0,0,0,30">
                        <TextBlock Text="❮" Foreground="#00E676" FontSize="24" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock Text="Ana Ekrana Dön" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#1AFFFFFF" CornerRadius="15" Padding="5" Margin="0,0,0,30" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="tabGun" MouseLeftButtonDown="Tab_Click" Background="#4AFFFFFF" CornerRadius="10" Padding="30,12,30,12" Cursor="Hand" Tag="GUN">
                                <TextBlock Text="GÜN" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="tabHafta" MouseLeftButtonDown="Tab_Click" Background="Transparent" CornerRadius="10" Padding="30,12,30,12" Cursor="Hand" Tag="HAFTA">
                                <TextBlock Text="HAFTALIK" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="tabAy" MouseLeftButtonDown="Tab_Click" Background="Transparent" CornerRadius="10" Padding="30,12,30,12" Cursor="Hand" Tag="AY">
                                <TextBlock Text="AYLIK" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="tabTum" MouseLeftButtonDown="Tab_Click" Background="Transparent" CornerRadius="10" Padding="30,12,30,12" Cursor="Hand" Tag="TUM">
                                <TextBlock Text="TÜM ZAMANLAR" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#60000000" CornerRadius="20" Padding="30">
                            <StackPanel>
                                <TextBlock x:Name="lblTabloBaslik" Text="BUGÜN TOPLAM" Foreground="#A0A0A5" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>
                                <TextBlock x:Name="lblSeciliToplam" Text="00s 00d" Foreground="#00E676" FontSize="80" FontWeight="Light"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#60000000" CornerRadius="20" Padding="30">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="KATEGORİ DAĞILIMI" Foreground="#A0A0A5" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>

                                <ListBox x:Name="viewListe" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1AFFFFFF" CornerRadius="8" Padding="15,10" Margin="0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="• " Foreground="White" FontSize="18" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Kategori}" Foreground="{Binding RenkFirca}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding SureMetni}" Foreground="White" FontSize="18" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Content="✍️" FontSize="16" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Tag="{Binding Kategori}" Click="btnKategoriDuzenle_Click"/>
                                                        <Button Content="🗑️" FontSize="16" Background="Transparent" BorderThickness="0" Cursor="Hand" Tag="{Binding Kategori}" Click="btnKategoriSil_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Canvas x:Name="viewGrafikPasta" Grid.Row="1" Visibility="Collapsed" Width="400" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ItemsControl x:Name="icPastaDilimleri">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="400" Height="300"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Path Data="{Binding DilimGeometrisi}" Fill="{Binding RenkFirca}" ToolTip="{Binding EtiketMetni}">
                                                        <Path.Effect>
                                                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="0" Opacity="0.3"/>
                                                        </Path.Effect>
                                                    </Path>
                                                    <Path Data="{Binding CizgiGeometrisi}" Stroke="{Binding RenkFirca}" StrokeThickness="1" Opacity="0.8"/>
                                                    <TextBlock Text="{Binding EtiketMetni}" Foreground="White" FontSize="12" FontFamily="Consolas">
                                                        <TextBlock.RenderTransform>
                                                            <TranslateTransform X="{Binding EtiketX}" Y="{Binding EtiketY}"/>
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Ellipse Width="120" Height="120" Fill="#2A000000" Canvas.Left="140" Canvas.Top="90">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Canvas>

                                <Grid x:Name="viewGrafikHaftalik" Grid.Row="1" Visibility="Collapsed" Margin="10,0,10,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <UniformGrid x:Name="gridSaatEkseni" Grid.Column="0" Grid.Row="0" Columns="1" Margin="0,0,10,0"/>
                                    <Canvas x:Name="viewCanvasHaftalik" Grid.Column="1" Grid.Row="0" Margin="0,0,0,10"/>
                                    <UniformGrid x:Name="gridGunEkseni" Grid.Column="1" Grid.Row="1" Columns="7" Margin="0,0,0,0"/>
                                </Grid>

                                <StackPanel x:Name="viewTakvim" Grid.Row="1" Visibility="Collapsed">
                                    <UniformGrid Columns="7" Margin="0,0,0,10">
                                        <TextBlock Text="Pt" Foreground="#A0A0A5" TextAlignment="Center"/>
                                        <TextBlock Text="Sa" Foreground="#A0A0A5" TextAlignment="Center"/>
                                        <TextBlock Text="Ça" Foreground="#A0A0A5" TextAlignment="Center"/>
                                        <TextBlock Text="Pe" Foreground="#A0A0A5" TextAlignment="Center"/>
                                        <TextBlock Text="Cu" Foreground="#A0A0A5" TextAlignment="Center"/>
                                        <TextBlock Text="Ct" Foreground="#A0A0A5" TextAlignment="Center"/>
                                        <TextBlock Text="Pa" Foreground="#A0A0A5" TextAlignment="Center"/>
                                    </UniformGrid>
                                    <UniformGrid x:Name="gridTakvimGunleri" Columns="7" Rows="6"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                                    <Button x:Name="btnGorunum1" Content="1" Width="30" Height="30" Background="#4AFFFFFF" Foreground="White" Margin="5" Cursor="Hand" Click="GorunumDegistir_Click" Tag="1"/>
                                    <Button x:Name="btnGorunum2" Content="2" Width="30" Height="30" Background="#2AFFFFFF" Foreground="White" Margin="5" Cursor="Hand" Click="GorunumDegistir_Click" Tag="2"/>
                                    <Button x:Name="btnGorunum3" Content="3" Width="30" Height="30" Background="#2AFFFFFF" Foreground="White" Margin="5" Cursor="Hand" Visibility="Collapsed" Click="GorunumDegistir_Click" Tag="3"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="ManuelKayitOverlay" Visibility="Collapsed" Background="#D0000000">
                <Border Background="#1C1C21" CornerRadius="20" Width="400" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                    <StackPanel>
                        <TextBlock Text="Ekstra Zaman Ekle" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Kategori Adı:" Foreground="#A0A0A5" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtManuelKategori" Background="#2A2A35" Foreground="White" BorderThickness="0" Padding="10" FontSize="16" Margin="0,0,0,15"/>
                        <TextBlock Text="Çalışma Süresi (Dakika):" Foreground="#A0A0A5" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtManuelSure" Background="#2A2A35" Foreground="White" BorderThickness="0" Padding="10" FontSize="16" Margin="0,0,0,20"/>
                        <TextBlock Text="Kategori Rengi:" Foreground="#A0A0A5" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                            <Button Background="#FF3B30" Width="30" Height="30" Margin="5" Cursor="Hand" Click="RenkSec_Click" Tag="#FF3B30"/>
                            <Button Background="#FF9500" Width="30" Height="30" Margin="5" Cursor="Hand" Click="RenkSec_Click" Tag="#FF9500"/>
                            <Button Background="#FFCC00" Width="30" Height="30" Margin="5" Cursor="Hand" Click="RenkSec_Click" Tag="#FFCC00"/>
                            <Button Background="#34C759" Width="30" Height="30" Margin="5" Cursor="Hand" Click="RenkSec_Click" Tag="#34C759"/>
                            <Button Background="#007AFF" Width="30" Height="30" Margin="5" Cursor="Hand" Click="RenkSec_Click" Tag="#007AFF"/>
                            <Button Background="#AF52DE" Width="30" Height="30" Margin="5" Cursor="Hand" Click="RenkSec_Click" Tag="#AF52DE"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="İPTAL" Width="120" Height="40" Background="#333340" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="btnManuelIptal_Click"/>
                            <Button Content="KAYDET" Width="120" Height="40" Background="#00E676" Foreground="#1C1C21" FontWeight="Bold" Cursor="Hand" Click="btnManuelKaydet_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="DuzenleOverlay" Visibility="Collapsed" Background="#D0000000">
                <Border Background="#1C1C21" CornerRadius="20" Width="400" Height="250" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                    <StackPanel>
                        <TextBlock x:Name="lblDuzenleBaslik" Text="Kategori Düzenle" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Yeni Toplam Süre (Dakika):" Foreground="#A0A0A5" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDuzenleSure" Background="#2A2A35" Foreground="White" BorderThickness="0" Padding="10" FontSize="16" Margin="0,0,0,30"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="İPTAL" Width="120" Height="40" Background="#333340" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="btnDuzenleIptal_Click"/>
                            <Button Content="GÜNCELLE" Width="120" Height="40" Background="#007AFF" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="btnDuzenleKaydet_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="ToastBildirim" Visibility="Collapsed" Background="#2A2A35" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0" Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✔️" Foreground="#00E676" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblToastMesaj" Text="Başarılı!" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>